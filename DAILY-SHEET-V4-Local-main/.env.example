# ══════════════════════════════════════════════════════════════════════════════
# Daily Sheet — Environment Variable Reference
# Copy this file to .env.local and fill in real values for local development.
# DO NOT commit .env.local or .env.production to source control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Backend ──────────────────────────────────────────────────────────────────

# Full Postgres connection string (required)
DATABASE_URL=postgresql://dailysheet:dailysheet@localhost:5432/dailysheet

# Session signing secret — must be at least 32 random characters (required)
SESSION_SECRET=change-me-to-a-random-32-char-or-longer-string

# Runtime environment: development | production
NODE_ENV=development

# Port the Express server listens on (default: 5000)
PORT=5000

# CORS — leave EMPTY when frontend and API share the same origin (same-origin proxy).
# Set to a comma-separated list of allowed origins ONLY for split-origin deployments
# e.g. CORS_ORIGIN=https://app.yourdomain.com,https://staging.yourdomain.com
CORS_ORIGIN=

# ── Optional integrations ─────────────────────────────────────────────────────

# Resend (email) — leave blank to skip sending emails (invites will be logged to console)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Daily Sheet <noreply@daily-sheet.app>

# Replit Object Storage — leave blank to use ./uploads/ disk fallback
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# OpenAI / AI features — leave blank to disable AI routes
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Frontend (Vite — must be prefixed VITE_) ──────────────────────────────────

# API base URL baked into the frontend bundle at build time.
#   /api          → same-origin (localhost with Caddy proxy, VPS with Nginx/Caddy)
#   https://...   → split-origin (Cloudflare Pages + Render)
VITE_API_URL=/api
